<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.GridPane?>

<GridPane xmlns="http://javafx.com/javafx/21"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="hu.alkfejl.view.VehicleCreateController"
          hgap="10" vgap="10">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Rendszám:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="plateField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Kategória:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <ComboBox fx:id="categoryBox" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Életkor:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <Spinner fx:id="ageSpinner" GridPane.rowIndex="2" GridPane.columnIndex="1" editable="true"/>

    <Label text="Aktív:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <CheckBox fx:id="activeCheck" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Button text="Mentés"
            onAction="#save"
            GridPane.rowIndex="4"
            GridPane.columnIndex="1"/>

</GridPane>